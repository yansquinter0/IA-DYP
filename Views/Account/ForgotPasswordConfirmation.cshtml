@{ ViewData["Title"] = "Revisa tu correo"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card text-center mx-3">
            <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width:80px; height:80px; border-radius:50%; background:rgba(30,214,136,.14);">
                <i class="bi bi-check-circle-fill text-success" style="font-size:2.5rem"></i>
            </div>
            <h2 class="fw-bold" style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:.04em;">¡Correo enviado!</h2>
            <p class="text-secondary">
                Si el correo está registrado en <strong class="text-white">DYPStore</strong>, recibirás un enlace para restablecer tu contraseña en unos minutos.
            </p>
            <hr class="border-secondary opacity-25 my-4">
            <a asp-action="Login" class="btn btn-outline-light w-100 fw-semibold"><i class="bi bi-arrow-left me-2"></i>Regresar al login</a>
        </div>
    </div>
</div>
