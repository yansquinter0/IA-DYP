@{ ViewData["Title"] = "Revisa tu correo"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card p-4 p-md-5 rounded-3 mx-3 text-center">
            <i class="bi bi-check-circle-fill text-success" style="font-size:3rem"></i>
            <h2 class="fw-bold text-uppercase mt-3">¡Correo Enviado!</h2>
            <p class="text-secondary">
                Si el correo está registrado en <strong>DYPStore</strong>, recibirás un enlace para restablecer tu contraseña en unos minutos.
            </p>
            <hr class="border-secondary opacity-25 my-4">
            <a asp-action="Login" class="btn btn-outline-danger w-100 fw-bold">Regresar al Inicio</a>
        </div>
    </div>
</div>