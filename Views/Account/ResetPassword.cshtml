@model DYPStore.Models.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Nueva Contraseña"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card mx-3">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center" style="width:72px; height:72px; border-radius:50%; background:rgba(255,45,77,.12);">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size:2rem"></i>
                </div>
                <h2 class="fw-bold mt-3" style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:.04em;">Nueva Contraseña</h2>
                <p class="text-secondary small mb-0">Crea una clave segura para tu cuenta.</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Nueva contraseña</label>
                    <input asp-for="Password" class="form-control dyp-input" placeholder="••••••••"
                           data-pwd-strength-target="#pwdBar" data-pwd-strength-label="#pwdLabel" />
                    <div class="dyp-pwd-strength"><div class="dyp-pwd-strength-bar" id="pwdBar"></div></div>
                    <div class="d-flex justify-content-between mt-1">
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <small id="pwdLabel" class="fw-semibold"></small>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Confirmar contraseña</label>
                    <input asp-for="ConfirmPassword" class="form-control dyp-input" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold">
                    <i class="bi bi-check-circle-fill me-2"></i>Actualizar Clave
                </button>
            </form>
        </div>
    </div>
</div>
