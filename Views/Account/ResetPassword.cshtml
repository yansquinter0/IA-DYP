@model DYPStore.Models.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Nueva Contraseña"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card p-4 p-md-5 rounded-3 mx-3">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size:2.5rem"></i>
                <h2 class="fw-bold text-uppercase mt-2">Nueva Contraseña</h2>
                <p class="text-secondary small">Crea una clave segura para tu cuenta.</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-secondary small text-uppercase fw-bold">Nueva Contraseña</label>
                    <input asp-for="Password" class="form-control dyp-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-secondary small text-uppercase fw-bold">Confirmar Contraseña</label>
                    <input asp-for="ConfirmPassword" class="form-control dyp-input" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold">
                    Actualizar Clave
                </button>
            </form>
        </div>
    </div>
</div>