@model RegisterViewModel
@{ ViewData["Title"] = "Registro"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:480px;">
        <div class="dyp-auth-card p-4 p-md-5 rounded-3 mx-3">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus-fill text-danger" style="font-size:2.5rem"></i>
                <h2 class="fw-bold text-uppercase mt-2">Crear Cuenta</h2>
                <p class="text-secondary small">Únete a la comunidad DYPStore</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="FullName" class="form-control dyp-input" placeholder="Tu nombre completo" autocomplete="name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Email" class="form-control dyp-input" placeholder="tu@correo.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Password" class="form-control dyp-input" placeholder="Mínimo 6 caracteres" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="ConfirmPassword" class="form-control dyp-input" placeholder="Repite tu contraseña" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold">
                    <i class="bi bi-person-check me-2"></i>Crear Cuenta
                </button>
            </form>

            <p class="text-center text-secondary small mt-4">
                ¿Ya tienes cuenta?
                <a asp-controller="Account" asp-action="Login" class="text-danger text-decoration-none fw-bold">Inicia sesión</a>
            </p>
        </div>
    </div>
</div>
