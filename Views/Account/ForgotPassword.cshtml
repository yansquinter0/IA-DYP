@model DYPStore.Models.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Recuperar Contraseña"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card p-4 p-md-5 rounded-3 mx-3 text-center">
            <div class="mb-4">
                <i class="bi bi-envelope-at text-danger" style="font-size:2.5rem"></i>
                <h2 class="fw-bold text-uppercase mt-2">¿Olvidaste tu clave?</h2>
                <p class="text-secondary small">Ingresa tu correo y te enviaremos un enlace de recuperación.</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4 text-start">
                    <label asp-for="Email" class="form-label text-secondary small text-uppercase fw-bold">Correo Electrónico</label>
                    <input asp-for="Email" class="form-control dyp-input" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold">
                    Enviar Enlace
                </button>
            </form>

            <p class="text-center text-secondary small mt-4">
                <a asp-action="Login" class="text-danger text-decoration-none fw-bold">Volver al Login</a>
            </p>
        </div>
    </div>
</div>