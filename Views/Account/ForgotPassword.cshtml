@model DYPStore.Models.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Recuperar Contraseña"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card text-center mx-3">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center" style="width:72px; height:72px; border-radius:50%; background:rgba(255,45,77,.12);">
                    <i class="bi bi-envelope-paper-heart text-danger" style="font-size:2rem"></i>
                </div>
                <h2 class="fw-bold mt-3" style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:.04em;">¿Olvidaste tu clave?</h2>
                <p class="text-secondary small mb-0">Ingresa tu correo y te enviaremos un enlace de recuperación.</p>
            </div>

            <form asp-action="ForgotPassword" method="post" class="text-start">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label asp-for="Email" class="form-label">Correo electrónico</label>
                    <input asp-for="Email" class="form-control dyp-input" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 btn-lg fw-bold">
                    <i class="bi bi-send-fill me-2"></i>Enviar Enlace
                </button>
            </form>

            <p class="text-center text-secondary small mt-4 mb-0">
                <a asp-action="Login" class="text-danger text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i>Volver al Login</a>
            </p>
        </div>
    </div>
</div>
