@{ ViewData["Title"] = "Contraseña Restablecida"; Layout = "_Layout"; }

<div class="min-vh-80 d-flex align-items-center justify-content-center py-5">
    <div class="w-100" style="max-width:440px;">
        <div class="dyp-auth-card p-4 p-md-5 rounded-3 mx-3 text-center">
            <i class="bi bi-check-circle-fill text-success" style="font-size:3rem"></i>
            <h2 class="fw-bold text-uppercase mt-3">¡Contraseña Actualizada!</h2>
            <p class="text-secondary">
                Tu contraseña ha sido restablecida exitosamente. Ahora puedes usar tu nueva clave para iniciar sesión en <strong>DYPStore</strong>.
            </p>
            <hr class="border-secondary opacity-25 my-4">
            <a asp-action="Login" class="btn btn-outline-danger w-100 fw-bold">Ir a Iniciar Sesión</a>
        </div>
    </div>
</div>
