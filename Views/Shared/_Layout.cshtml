<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DYPStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark dyp-navbar sticky-top">
    <div class="container">
        <a class="navbar-brand dyp-logo" asp-controller="Home" asp-action="Index">
            <i class="bi bi-lightning-fill text-danger"></i> DYP<span class="text-danger">Store</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Inicio
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Products"?"active":"")" asp-controller="Products" asp-action="Index">
                        <i class="bi bi-grid me-1"></i>Tienda
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-shield-lock-fill me-1"></i>Admin
                        </a>
                    </li>
                }
            </ul>
            <ul class="navbar-nav align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3 fs-5"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Orders" asp-action="Index">
                            <i class="bi bi-bag-check me-1"></i><span class="d-none d-lg-inline">Pedidos</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i><span class="d-none d-lg-inline">@User.Identity?.Name?.Split('@')[0]</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dyp-dropdown">
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" onsubmit="Object.keys(localStorage).forEach(k => { if(k.startsWith('sb-')) localStorage.removeItem(k); });">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Ingresar</a></li>
                    <li class="nav-item"><a class="btn btn-danger btn-sm px-3" asp-controller="Account" asp-action="Register">Registro</a></li>
                }
            </ul>
        </div>
    </div>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert" style="background:#1a3a1a;color:#6fcf6f;">
        <div class="container"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]</div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert" style="background:#3a1a1a;color:#eb5757;">
        <div class="container"><i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]</div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
    </div>
}

<main>@RenderBody()</main>

<footer class="dyp-footer mt-5">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="dyp-logo fs-4 mb-3"><i class="bi bi-lightning-fill text-danger"></i> DYP<span class="text-danger">Store</span></div>
                <p class="text-secondary small">Tu destino definitivo para equipamiento de boxeo, calzado deportivo de alto rendimiento y suplementos premium.</p>
            </div>
            <div class="col-6 col-md-4">
                <h6 class="text-uppercase fw-bold mb-3 text-light">Categorías</h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><a asp-controller="Products" asp-action="Index" asp-route-category="boxing" class="text-secondary text-decoration-none"><i class="bi bi-shield-fill me-1 text-danger"></i>Boxeo</a></li>
                    <li class="mb-2"><a asp-controller="Products" asp-action="Index" asp-route-category="shoes" class="text-secondary text-decoration-none"><i class="bi bi-lightning me-1 text-primary"></i>Tenis Deportivos</a></li>
                    <li class="mb-2"><a asp-controller="Products" asp-action="Index" asp-route-category="supplements" class="text-secondary text-decoration-none"><i class="bi bi-droplet-fill me-1 text-success"></i>Suplementos</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-4">
                <h6 class="text-uppercase fw-bold mb-3 text-light">Soporte</h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Contacto</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Envíos</a></li>
                    <li class="mb-2"><a href="#" class="text-secondary text-decoration-none">Devoluciones</a></li>
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-4" />
        <p class="text-center text-secondary small mb-0">&copy; @DateTime.Now.Year DYPStore. Todos los derechos reservados.</p>
    </div>
</footer>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
