                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")" asp-controller="Home" asp-action="Index">Inicio</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString()=="Products"?"active":"")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Tienda
                    </a>
                    <ul class="dropdown-menu dyp-dropdown">
                        <li><span class="dyp-dropdown-header">Categorías</span></li>
                        <li><a class="dropdown-item" asp-controller="Products" asp-action="Index"><i class="bi bi-grid-3x3-gap me-2"></i>Todos los productos</a></li>
                        <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-category="boxing"><i class="bi bi-shield-fill text-danger me-2"></i>Boxeo</a></li>
                        <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-category="shoes"><i class="bi bi-lightning-charge text-primary me-2"></i>Tenis Deportivos</a></li>
                        <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-category="supplements"><i class="bi bi-droplet-fill text-success me-2"></i>Suplementos</a></li>
                    </ul>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-shield-lock-fill text-warning me-1"></i>Admin
                        </a>
                    </li>
                }
            </ul>

            <form class="dyp-search-pill d-none d-lg-flex me-3" asp-controller="Products" asp-action="Index" method="get" role="search">
                <i class="bi bi-search text-secondary me-2"></i>
                <input type="search" name="search" placeholder="Buscar guantes, tenis, proteína... (presiona /)" value="@currentSearch" autocomplete="off" />
                <button type="button" class="dyp-voice-btn" title="Buscar por voz" aria-label="Buscar por voz"><i class="bi bi-mic-fill"></i></button>
                <button type="submit" aria-label="Buscar"><i class="bi bi-arrow-right"></i></button>
            </form>

            <ul class="navbar-nav align-items-center gap-2">
                <li class="nav-item">
                    <button type="button" class="dyp-theme-toggle" title="Cambiar tema (T)" aria-label="Cambiar tema"><i class="bi bi-sun-fill"></i></button>
                </li>
                <li class="nav-item">
                    <button type="button" class="dyp-icon-btn" data-drawer-open="dypWishDrawer" title="Lista de deseos (W)" aria-label="Lista de deseos">
                        <i class="bi bi-heart fs-5"></i>
                    </button>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="dyp-icon-btn" asp-controller="Cart" asp-action="Index" aria-label="Carrito">
                            <i class="bi bi-bag fs-5"></i>
                            @{ var cartCount = ViewBag.CartItemCount as int?; }
                            @if (cartCount.HasValue && cartCount.Value > 0)
                            {
                                <span class="dyp-cart-count">@cartCount.Value</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="dyp-icon-btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" style="text-decoration:none;" aria-expanded="false">
                            <i class="bi bi-person fs-5"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dyp-dropdown" style="min-width:240px;">
                            <li>
                                <div class="px-2 py-2">
                                    <div class="text-secondary small">Sesión activa</div>
                                    <div class="fw-bold text-truncate" style="max-width:220px;">@User.Identity?.Name</div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider border-secondary opacity-25"/></li>
                            <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Mis Pedidos</a></li>
                            <li><a class="dropdown-item" asp-controller="Cart" asp-action="Index"><i class="bi bi-bag me-2"></i>Mi Carrito</a></li>
                            <li><a class="dropdown-item" href="#" data-drawer-open="dypWishDrawer"><i class="bi bi-heart me-2"></i>Mis Favoritos</a></li>
                            <li><a class="dropdown-item" href="/Account/FaceEnroll"><i class="bi bi-shield-lock-fill me-2 text-danger"></i>Configurar Face ID</a></li>
                            <li><a class="dropdown-item" href="#" data-kbd-open><i class="bi bi-keyboard me-2"></i>Atajos de teclado</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-shield-lock me-2"></i>Panel Admin</a></li>
                            }
                            <li><hr class="dropdown-divider border-secondary opacity-25"/></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" onsubmit="Object.keys(localStorage).forEach(k => { if(k.startsWith('sb-')) localStorage.removeItem(k); });">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Ingresar</a></li>
                    <li class="nav-item"><a class="btn btn-danger btn-sm px-3" asp-controller="Account" asp-action="Register">Crear cuenta</a></li>
                }
