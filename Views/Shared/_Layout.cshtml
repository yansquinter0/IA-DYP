<!-- ===== DYPSTORE INTRO SCREEN — JS ===== -->
<script>
(function () {
    var intro  = document.getElementById('dypstore-intro');
    var body   = document.body;
    var TOTAL  = 5000; // duración total en ms

    // ── Solo una vez por sesión ──────────────────────────────────────────
    if (sessionStorage.getItem('dypIntroShown')) {
        intro.style.display = 'none';
        body.classList.remove('dyp-intro-active');
        return;
    }
    sessionStorage.setItem('dypIntroShown', '1');

    // ── Canvas de rayas de luz (estilo Netflix 2019) ─────────────────────
    var canvas = document.getElementById('dyp-intro-canvas');
    var ctx    = canvas.getContext('2d');
    var W, H, rafId, streaks = [];
    var streakPhase = false;   // se activa en el momento del zoom explosivo

    function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    // Colores del espectro Netflix (rojo, naranja, verde, azul, cyan…)
    var COLORS = [
        '#E50914','#ff4500','#ff6a00',
        '#ff0080','#b22222',
        '#00c853','#1de9b6',
        '#2979ff','#00b0ff','#40c4ff',
        '#aa00ff','#d500f9',
        '#ffd600','#ffab00',
        '#fff','#f44336'
    ];

    function makeStreak() {
        var x     = (Math.random() * 1.4 - 0.2) * W;
        var color = COLORS[(Math.random() * COLORS.length) | 0];
        return {
            x:      x,
            w:      0.5 + Math.random() * 2.5,
            speed:  2 + Math.random() * 6,
            alpha:  0.15 + Math.random() * 0.85,
            color:  color,
            glow:   Math.random() > 0.5,
            life:   0,
            maxLife: 40 + Math.random() * 80
        };
    }

    function drawStreaks(progress) {
        ctx.clearRect(0, 0, W, H);
        if (!streakPhase) return;

        // Añadir nuevas rayas gradualmente
        var density = Math.min(1, progress) * 5;
        for (var i = 0; i < density; i++) {
            if (Math.random() < 0.35) streaks.push(makeStreak());
        }

        streaks.forEach(function(s) {
            s.life++;
            var fade = s.life < 8
                ? s.life / 8
                : s.life > s.maxLife * 0.75
                    ? 1 - (s.life - s.maxLife * 0.75) / (s.maxLife * 0.25)
                    : 1;
            var a = s.alpha * fade * Math.min(1, progress * 1.4);

            if (s.glow) {
                var grd = ctx.createLinearGradient(s.x, 0, s.x + s.w * 4, H);
                grd.addColorStop(0, 'transparent');
                grd.addColorStop(0.3, hexAlpha(s.color, a * 0.4));
                grd.addColorStop(0.5, hexAlpha(s.color, a));
                grd.addColorStop(0.7, hexAlpha(s.color, a * 0.4));
                grd.addColorStop(1,   'transparent');
                ctx.fillStyle = grd;
                ctx.fillRect(s.x - s.w * 2, 0, s.w * 6, H);
            }

            ctx.globalAlpha = a;
            ctx.fillStyle   = s.color;
            ctx.fillRect(s.x, 0, s.w, H);
            ctx.globalAlpha = 1;
        });

        // Eliminar rayas viejas
        streaks = streaks.filter(function(s) { return s.life < s.maxLife; });
    }

    function hexAlpha(hex, a) {
        var r = parseInt(hex.slice(1,3)||'ff', 16);
        var g = parseInt(hex.slice(3,5)||'00', 16);
        var b = parseInt(hex.slice(5,7)||'00', 16);
        return 'rgba('+r+','+g+','+b+','+a.toFixed(3)+')';
    }

    var startTime = null;
    function tick(ts) {
        if (!startTime) startTime = ts;
        var elapsed  = ts - startTime;
        var streakProgress = Math.max(0, (elapsed - 2800) / 1400); // empieza a los 2.8s
        drawStreaks(streakProgress);
        rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);

    // Activar fase de rayas en el momento del zoom explosivo
    setTimeout(function() { streakPhase = true; }, 2800);

    // Fade-out final de toda la pantalla
    setTimeout(function() {
        intro.style.animation = 'dypIntroFadeOut 0.6s ease forwards';
    }, TOTAL - 650);

    // Ocultar completamente al terminar
    setTimeout(function() {
        cancelAnimationFrame(rafId);
        intro.style.display = 'none';
        body.classList.remove('dyp-intro-active');
    }, TOTAL);

    // ── Sonido Ta-Dum (Web Audio API) ────────────────────────────────────
    function buildTaDum(ac) {
        var comp = ac.createDynamicsCompressor();
        comp.threshold.value = -12;
        comp.ratio.value     = 6;
        comp.connect(ac.destination);

        function note(type, f0, f1, vol, dur, t) {
            var osc  = ac.createOscillator();
            var gain = ac.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(f0, t);
            osc.frequency.exponentialRampToValueAtTime(f1, t + dur * 0.85);
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(vol, t + 0.014);
            gain.gain.exponentialRampToValueAtTime(0.0001, t + dur);
            osc.connect(gain); gain.connect(comp);
            osc.start(t); osc.stop(t + dur + 0.05);
        }

        var now = ac.currentTime + 0.08;
        note('sine',     390, 105, 0.82, 0.22, now);
        note('triangle', 290,  90, 0.28, 0.18, now);
        var t2 = now + 0.40;
        note('sine',      76,  36, 1.00, 0.95, t2);
        note('sine',     152,  72, 0.30, 0.60, t2);
        note('triangle', 230,  95, 0.18, 0.40, t2);
    }

    function playTaDum() {
        try {
            var AC = window.AudioContext || window.webkitAudioContext;
            if (!AC) return;
            var ac = new AC();
            if (ac.state === 'running') {
                buildTaDum(ac);
                setTimeout(function(){ try{ ac.close(); }catch(e){} }, 3000);
            } else {
                var played = false;
                var evts   = ['click','touchstart','keydown','scroll','mousemove'];
                function onFirst() {
                    if (played) return; played = true;
                    evts.forEach(function(e){ document.removeEventListener(e, onFirst, true); });
                    ac.resume().then(function(){
                        buildTaDum(ac);
                        setTimeout(function(){ try{ ac.close(); }catch(e){} }, 3000);
                    });
                }
                evts.forEach(function(e){ document.addEventListener(e, onFirst, { capture:true, once:true }); });
            }
        } catch(e) {}
    }

    playTaDum();
})();
</script>

