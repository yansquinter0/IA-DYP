@{
    var currentSearch = Context.Request.Query["search"].ToString();
}
<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07070a" />
    <title>@ViewData["Title"] · DYPStore — Equipamiento Deportivo Premium</title>
    <script>
        (function(){
            try {
                var t = JSON.parse(localStorage.getItem('dypx_theme')) || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            } catch(e){}
        })();
    </script>
    <link rel="manifest" href="~/manifest.json" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- ===== DYPSTORE INTRO SCREEN — CSS ===== -->
    <style>
        #dypstore-intro {
            position: fixed;
            inset: 0;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            overflow: hidden;
        }

        /* Canvas de rayas de luz — cubre toda la pantalla */
        #dyp-intro-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        /* Contenedor del logo con clip para el reveal */
        .dyp-intro-wrap {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: dypLogoAnim 4.4s cubic-bezier(0.16,1,0.3,1) forwards;
        }

        /* Barra roja inicial */
        .dyp-intro-bar {
            position: absolute;
            width: 10px;
            height: 0;
            background: #E50914;
            border-radius: 2px;
            animation: dypBarGrow 0.55s cubic-bezier(0.22,1,0.36,1) 0.1s forwards;
            box-shadow: 0 0 30px 6px rgba(229,9,20,0.7);
        }

        /* Texto DYPStore */
        .dyp-intro-logo {
            font-family: 'Barlow Condensed', 'Arial Black', Arial, sans-serif;
            font-weight: 900;
            font-size: clamp(3.5rem, 12vw, 9rem);
            letter-spacing: 0.05em;
            text-transform: uppercase;
            line-height: 1;
            user-select: none;
            white-space: nowrap;
            clip-path: inset(0 100% 0 0);
            animation: dypTextReveal 0.6s cubic-bezier(0.22,1,0.36,1) 0.7s forwards;
            opacity: 0;
        }
        .dyp-intro-logo .dyp   { color: #E50914; }
        .dyp-intro-logo .store { color: #FFFFFF; }

        /* Fase 1: barra crece en altura */
        @@keyframes dypBarGrow {
            0%   { height: 0; opacity: 0; }
            20%  { opacity: 1; }
            100% { height: clamp(120px, 22vw, 200px); }
        }

        /* Fase 2: texto se revela de izquierda a derecha */
        @@keyframes dypTextReveal {
            0%   { clip-path: inset(0 100% 0 0); opacity: 1; }
            100% { clip-path: inset(0 0%   0 0); opacity: 1; }
        }

        /* Fase 3+4: zoom explosivo + fade */
        @@keyframes dypLogoAnim {
            0%,  16%  { transform: scale(1);    opacity: 1; filter: blur(0px); }
            50%        { transform: scale(1.04); opacity: 1; filter: blur(0px); }
            68%        { transform: scale(1.12); opacity: 1; filter: blur(0px); }
            82%        { transform: scale(2.8);  opacity: 0.6; filter: blur(3px); }
            92%        { transform: scale(5.5);  opacity: 0;   filter: blur(10px); }
            100%       { transform: scale(6);    opacity: 0;   filter: blur(12px); }
        }

        /* Fade final de toda la pantalla */
        @@keyframes dypIntroFadeOut {
            0%   { opacity: 1; }
            100% { opacity: 0; visibility: hidden; pointer-events: none; }
        }

        body.dyp-intro-active { overflow: hidden; }
    </style>
</head>
<body class="dyp-intro-active" data-authenticated="@(User.Identity?.IsAuthenticated == true ? "true" : "false")" data-admin="@(User.IsInRole("Admin") ? "true" : "false")">

<!-- ===== DYPSTORE INTRO SCREEN — HTML ===== -->
<div id="dypstore-intro" role="presentation" aria-hidden="true">
    <canvas id="dyp-intro-canvas"></canvas>
    <div class="dyp-intro-wrap">
        <div class="dyp-intro-bar"></div>
        <span class="dyp-intro-logo">
            <span class="dyp">DYP</span><span class="store">Store</span>
        </span>
    </div>
</div>
