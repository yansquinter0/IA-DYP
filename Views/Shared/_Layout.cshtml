<div id="dypChatPanel" class="dyp-chatbot-panel" role="dialog" aria-label="Asistente de DYPStore">
    <!-- Header -->
    <div class="dyp-chatbot-header">
        <div class="dyp-chatbot-header-icon"><i class="bi bi-lightning-charge-fill"></i></div>
        <div class="dyp-chatbot-header-info">
            <strong>Asistente DYPStore</strong>
            <small>En línea</small>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <span class="dyp-chatbot-role-badge admin">Admin</span>
        }
        else if (User.Identity?.IsAuthenticated == true)
        {
            <span class="dyp-chatbot-role-badge user">User</span>
        }
    </div>

    <!-- Messages -->
    <div id="dypChatMessages" class="dyp-chatbot-messages"></div>

    <!-- Quick chips -->
    <div id="dypChatChips" class="dyp-chatbot-chips"></div>

    <!-- Input area -->
    <div class="dyp-chatbot-input-area">
        <input id="dypChatInput" type="text" placeholder="Escribe o usa el micrófono..." maxlength="500" autocomplete="off" />
        <button type="button" id="dypChatVoiceBtn" class="dyp-chat-voice-btn" title="Dictar mensaje" aria-label="Dictar mensaje">
            <i class="bi bi-mic-fill"></i>
        </button>
        <button type="button" id="dypChatSendBtn" class="dyp-chat-send-btn" aria-label="Enviar">
