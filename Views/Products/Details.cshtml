@model Product
@{ ViewData["Title"] = Model.Name; }

<div class="container py-4 py-md-5">
    <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left me-1"></i>Volver a la tienda
    </a>
    <div class="row g-4 g-lg-5">
        <div class="col-12 col-lg-6">
            <div class="dyp-detail-img-wrap">
                <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=800&q=80")" alt="@Model.Name" class="img-fluid" style="max-height:450px;object-fit:contain;" />
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="dyp-badge-cat dyp-cat-@Model.Category.ToString().ToLower()">@Model.Category.ToString().ToUpper()</span>
                <span class="text-secondary fw-bold text-uppercase small">@Model.Brand</span>
            </div>
            <h1 class="fw-bold text-uppercase mb-3" style="font-size:clamp(1.5rem,4vw,2.5rem);">@Model.Name</h1>
            <p class="dyp-price-lg mb-4">$@Model.Price.ToString("N2")</p>
            <p class="text-secondary mb-4">@Model.Description</p>

            <div class="dyp-info-box p-3 rounded-3 mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-secondary">Disponibilidad</span>
                    @if (Model.Stock > 0)
                    { <span class="text-success fw-bold"><i class="bi bi-lightning-fill me-1"></i>En Stock (@Model.Stock)</span> }
                    else { <span class="text-danger fw-bold">Agotado</span> }
                </div>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Cart" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="d-flex gap-3 align-items-center mb-4">
                        <div class="dyp-qty-control d-flex align-items-center gap-0">
                            <button type="button" class="btn btn-outline-secondary px-3 qty-btn" data-action="dec">-</button>
                            <input type="number" name="quantity" id="qtyInput" class="form-control text-center border-secondary qty-input" value="1" min="1" max="@Model.Stock" style="width:60px;background:#111;color:#fff;" readonly />
                            <button type="button" class="btn btn-outline-secondary px-3 qty-btn" data-action="inc" data-max="@Model.Stock">+</button>
                        </div>
                        <button type="submit" class="btn btn-danger btn-lg flex-grow-1" @(Model.Stock<=0?"disabled":"")>
                            <i class="bi bi-cart-plus me-2"></i>Añadir al Carrito
                        </button>
                    </div>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-danger btn-lg w-100 mb-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Inicia sesión para comprar
                </a>
            }

            <div class="row g-3">
                <div class="col-6">
                    <div class="dyp-info-box p-3 rounded-3 d-flex align-items-center gap-2">
                        <i class="bi bi-shield-check text-danger fs-4"></i>
                        <small class="text-secondary">Garantía de Calidad Premium</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="dyp-info-box p-3 rounded-3 d-flex align-items-center gap-2">
                        <i class="bi bi-truck text-danger fs-4"></i>
                        <small class="text-secondary">Envíos a todo el país</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.qty-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const input = document.getElementById('qtyInput');
        let v = parseInt(input.value);
        const max = parseInt(btn.dataset.max || 99);
        if (btn.dataset.action === 'inc') v = Math.min(v + 1, max);
        else v = Math.max(v - 1, 1);
        input.value = v;
    });
});
</script>
}
