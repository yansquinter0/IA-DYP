@model IEnumerable<Order>
@{ ViewData["Title"] = "Mis Pedidos"; }

<div class="container py-4 py-md-5">
    <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <div class="dyp-section-eyebrow">Tu historial</div>
            <h1 class="dyp-section-title">Mis pedidos</h1>
        </div>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-bag-plus me-2"></i>Comprar más</a>
    </div>

    @if (!Model.Any())
    {
        <div class="dyp-empty">
            <div class="icon-wrap"><i class="bi bi-bag-check"></i></div>
            <h4>Aún no tienes pedidos</h4>
            <p>Cuando completes una compra aparecerá aquí. Empieza a llenar tu próxima sesión.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-danger"><i class="bi bi-bag-plus me-2"></i>Ir a la tienda</a>
        </div>
    }
    else
    {
        <div class="dyp-reveal-stagger">
            @foreach (var order in Model)
            {
                var statusKey = order.Status.ToString().ToLower();
                var stepStates = order.Status switch {
                    OrderStatus.cancelled => new[] { "done", "cancelled", "cancelled", "cancelled" },
                    OrderStatus.pending => new[] { "current", "", "", "" },
                    OrderStatus.processing => new[] { "done", "current", "", "" },
                    OrderStatus.completed => new[] { "done", "done", "done", "done" },
                    _ => new[] { "", "", "", "" }
                };
                <div class="dyp-order-card mb-4">
                    <div class="dyp-order-header d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div class="d-flex gap-4 flex-wrap">
                            <div>
                                <div class="dyp-order-meta">Pedido</div>
                                <div class="dyp-order-id">#@order.Id.ToString("D6")</div>
                            </div>
                            <div>
                                <div class="dyp-order-meta">Fecha</div>
                                <div class="text-white fw-semibold">@order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                            </div>
                            <div>
                                <div class="dyp-order-meta">Items</div>
                                <div class="text-white fw-semibold">@order.Items.Sum(i => i.Quantity)</div>
                            </div>
                        </div>
                        <div class="d-flex gap-3 align-items-center flex-wrap">
                            <div class="text-end">
                                <div class="dyp-order-meta">Total</div>
                                <div class="dyp-price">$@order.Total.ToString("N0")</div>
                            </div>
                            <span class="dyp-status @statusKey">@order.Status.ToString()</span>
                        </div>
                    </div>
                    <div class="px-4 pt-3">
                        @if (order.Status != OrderStatus.cancelled)
                        {
                            <div class="dyp-timeline">
                                <div class="dyp-timeline-step @stepStates[0]"><div class="dot"><i class="bi bi-bag-check"></i></div><div class="label">Recibido</div></div>
                                <div class="dyp-timeline-line @(stepStates[1] != "" ? "done" : "")"></div>
                                <div class="dyp-timeline-step @stepStates[1]"><div class="dot"><i class="bi bi-box-seam"></i></div><div class="label">Procesando</div></div>
                                <div class="dyp-timeline-line @(stepStates[2] != "" ? "done" : "")"></div>
                                <div class="dyp-timeline-step @stepStates[2]"><div class="dot"><i class="bi bi-truck"></i></div><div class="label">En envío</div></div>
                                <div class="dyp-timeline-line @(stepStates[3] != "" ? "done" : "")"></div>
                                <div class="dyp-timeline-step @stepStates[3]"><div class="dot"><i class="bi bi-house-check"></i></div><div class="label">Entregado</div></div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger mb-3"><i class="bi bi-x-octagon me-2"></i>Este pedido fue cancelado.</div>
                        }
                    </div>
                    <div class="px-4 pb-4">
                        <div class="dyp-order-meta mb-2">Productos</div>
                        @foreach (var item in order.Items)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid var(--dyp-border);">
                                <div class="d-flex align-items-center gap-3 min-w-0">
                                    <span class="badge bg-secondary">@item.Quantity&times;</span>
                                    <span class="text-white text-truncate">@item.ProductName</span>
                                </div>
                                <span class="text-secondary font-monospace small flex-shrink-0">$@item.UnitPrice.ToString("N0")</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
