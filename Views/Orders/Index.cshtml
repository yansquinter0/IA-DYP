@model IEnumerable<Order>
@{ ViewData["Title"] = "Mis Pedidos"; }

<div class="container py-4 py-md-5 max-w-3xl">
    <h1 class="dyp-section-title mb-4"><i class="bi bi-bag-check me-2"></i>Mis Pedidos</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5 dyp-summary-box rounded-3">
            <i class="bi bi-bag-x" style="font-size:4rem;opacity:.2"></i>
            <p class="mt-3 text-secondary">No tienes pedidos anteriores.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-danger">Ir a la tienda</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="dyp-summary-box rounded-3 mb-4 overflow-hidden">
                <div class="p-3 d-flex flex-wrap justify-content-between align-items-center gap-3" style="background:#111;border-bottom:1px solid #222;">
                    <div class="d-flex gap-4 flex-wrap">
                        <div>
                            <div class="text-secondary small text-uppercase">Pedido #</div>
                            <div class="fw-bold font-monospace">@order.Id.ToString("D6")</div>
                        </div>
                        <div>
                            <div class="text-secondary small text-uppercase">Fecha</div>
                            <div class="fw-bold">@order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-center flex-wrap">
                        <div class="text-end">
                            <div class="text-secondary small">Total</div>
                            <div class="dyp-price">$@order.Total.ToString("N2")</div>
                        </div>
                        @{
                            var badge = order.Status switch {
                                OrderStatus.completed => "bg-success",
                                OrderStatus.pending => "bg-warning text-dark",
                                OrderStatus.processing => "bg-info text-dark",
                                OrderStatus.cancelled => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badge">@order.Status.ToString().ToUpper()</span>
                    </div>
                </div>
                <div class="p-4">
                    @foreach (var item in order.Items)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary">@item.Quantity&#xd7;</span>
                                <span>@item.ProductName</span>
                            </div>
                            <span class="text-secondary font-monospace small">$@item.UnitPrice.ToString("N2")</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
