@model CartViewModel
@{ ViewData["Title"] = "Carrito"; }

<div class="container py-4 py-md-5">
    <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <div class="dyp-section-eyebrow">Casi listo</div>
            <h1 class="dyp-section-title">Tu carrito</h1>
        </div>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-2"></i>Seguir comprando</a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="dyp-empty">
            <div class="icon-wrap"><i class="bi bi-bag"></i></div>
            <h4>Tu carrito está vacío</h4>
            <p>Aún no has añadido productos. Explora la tienda y empieza a llenar tu próximo pedido.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-danger"><i class="bi bi-bag-plus me-2"></i>Ir a la tienda</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8 dyp-reveal-stagger">
                @foreach (var item in Model.Items)
                {
                    <div class="dyp-cart-item mb-3">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">
                            <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=200&q=80")" alt="@item.ProductName" class="dyp-cart-img" />
                        </a>
                        <div class="flex-grow-1 min-w-0">
                            <div class="dyp-brand mb-1">@item.Brand</div>
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-white text-decoration-none fw-semibold d-block mb-1" style="font-size:1.02rem;">@item.ProductName</a>
                            <div class="text-secondary small mb-2">$@item.UnitPrice.ToString("N0") c/u</div>
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="dyp-qty">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" name="quantity" value="@(item.Quantity-1)" @(item.Quantity<=1?"disabled":"")>−</button>
                                    <input type="number" value="@item.Quantity" readonly />
                                    <button type="submit" name="quantity" value="@(item.Quantity+1)" @(item.Quantity>=item.Stock?"disabled":"")>+</button>
                                </form>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="dyp-price">$@item.Subtotal.ToString("N0")</span>
                                    <form asp-controller="Cart" asp-action="Remove" method="post" data-confirm="¿Quitar este producto del carrito?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Eliminar"><i class="bi bi-trash3"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-12 col-lg-4">
                <div class="dyp-summary-box" style="position:sticky; top:90px;">
                    <h5 class="fw-bold text-uppercase mb-3" style="font-family:'Barlow Condensed',sans-serif; letter-spacing:.05em;">Resumen del pedido</h5>
                    <div class="dyp-summary-row">
                        <span>Subtotal (@Model.ItemCount @(Model.ItemCount == 1 ? "item" : "items"))</span>
                        <span class="text-white fw-semibold">$@Model.Total.ToString("N0")</span>
                    </div>
                    <div class="dyp-summary-row">
                        <span>Envío</span>
                        <span class="text-success fw-semibold">Gratis</span>
                    </div>
                    <div class="dyp-promo-input">
                        <input type="text" placeholder="Código promocional" />
                        <button type="button" class="btn btn-outline-light btn-sm">Aplicar</button>
                    </div>
                    <div class="dyp-summary-row total">
                        <span style="font-size:1.05rem;">Total</span>
                        <span class="dyp-price" style="font-size:1.6rem;">$@Model.Total.ToString("N0")</span>
                    </div>
                    <form asp-controller="Cart" asp-action="Checkout" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 btn-lg">
                            <i class="bi bi-bag-check-fill me-2"></i>Completar Compra
                        </button>
                    </form>
                    <div class="dyp-trust-mini">
                        <span><i class="bi bi-shield-lock-fill"></i>Pago seguro</span>
                        <span><i class="bi bi-arrow-counterclockwise"></i>30 días</span>
                        <span><i class="bi bi-truck"></i>Envío rápido</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
