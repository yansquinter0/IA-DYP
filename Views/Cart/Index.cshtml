@model CartViewModel
@{ ViewData["Title"] = "Carrito"; }

<div class="container py-4 py-md-5">
    <h1 class="dyp-section-title mb-4"><i class="bi bi-cart3 me-2"></i>Carrito de Compras</h1>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size:5rem;opacity:.2"></i>
            <h4 class="mt-3 text-uppercase fw-bold">Tu carrito está vacío</h4>
            <p class="text-secondary">Aún no has añadido productos a tu carrito.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-danger mt-2">Ir a la tienda</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                @foreach (var item in Model.Items)
                {
                    <div class="dyp-cart-item d-flex gap-3 p-3 p-md-4 mb-3">
                        <img src="@(item.ImageUrl ?? "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=200&q=80")"
                             alt="@item.ProductName" class="rounded-3 object-fit-cover flex-shrink-0" style="width:80px;height:80px;object-fit:cover;" />
                        <div class="flex-grow-1 min-w-0">
                            <div class="text-danger small fw-bold text-uppercase">@item.Brand</div>
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId"
                               class="text-white text-decoration-none fw-bold">@item.ProductName</a>
                            <div class="text-secondary small">$@item.UnitPrice.ToString("N2") c/u</div>
                            <div class="d-flex align-items-center justify-content-between mt-2 flex-wrap gap-2">
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" name="quantity" value="@(item.Quantity-1)" class="btn btn-outline-secondary btn-sm px-2">-</button>
                                    <span class="px-3 fw-bold">@item.Quantity</span>
                                    <button type="submit" name="quantity" value="@(item.Quantity+1)" class="btn btn-outline-secondary btn-sm px-2" @(item.Quantity>=item.Stock?"disabled":"")>+</button>
                                </form>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="dyp-price">$@item.Subtotal.ToString("N2")</span>
                                    <form asp-controller="Cart" asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-12 col-lg-4">
                <div class="dyp-summary-box p-4 rounded-3 sticky-top" style="top:80px;">
                    <h5 class="fw-bold text-uppercase mb-4 pb-3 border-bottom border-secondary">Resumen del Pedido</h5>
                    <div class="d-flex justify-content-between mb-2 text-secondary">
                        <span>Subtotal (@Model.ItemCount items)</span><span>$@Model.Total.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 text-success">
                        <span>Envío</span><span>Gratis</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 pt-3 border-top border-secondary">
                        <span class="fw-bold fs-5">Total</span>
                        <span class="dyp-price fs-4">$@Model.Total.ToString("N2")</span>
                    </div>
                    <form asp-controller="Cart" asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 btn-lg">
                            <i class="bi bi-bag-check me-2"></i>Completar Compra
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
