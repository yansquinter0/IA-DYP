@{ ViewData["Title"] = "Acceso Denegado"; }

<div class="container d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh; padding: 60px 20px;">
    <div class="text-center" style="max-width: 480px;">
        <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width:96px; height:96px; border-radius:50%; background:rgba(255,181,71,.14);">
            <i class="bi bi-shield-lock-fill text-warning" style="font-size:2.8rem"></i>
        </div>
        <h1 class="display-5 fw-bold text-warning" style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:.02em;">Acceso Denegado</h1>
        <p class="text-secondary fs-5 mt-2 mb-4">No tienes permisos para ver esta página. Inicia sesión con una cuenta autorizada para continuar.</p>
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-danger btn-lg px-4"><i class="bi bi-house-fill me-2"></i>Volver al inicio</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-4"><i class="bi bi-box-arrow-in-right me-2"></i>Iniciar sesión</a>
        </div>
    </div>
</div>
