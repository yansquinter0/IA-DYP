@model IEnumerable<DYPStore.Models.ChatLog>
@{
    ViewData["Title"] = "Auditoría IA";
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var filterRole = ViewBag.FilterRole as string;
    var filterIntent = ViewBag.FilterIntent as string;
    var filterWriteOnly = ViewBag.FilterWriteOnly as bool?;
    var allIntents = ViewBag.AllIntents as List<string> ?? new List<string>();
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <div class="dyp-section-eyebrow">Inteligencia Artificial</div>
        <h2 class="dyp-section-title mb-0">Auditoría del Chatbot</h2>
    </div>
    <form asp-area="Admin" asp-controller="Dashboard" asp-action="ClearChatLogs" method="post"
          onsubmit="return confirm('¿Eliminar TODO el historial de chat? Esta acción no se puede deshacer.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-trash3 me-1"></i>Limpiar historial
        </button>
    </form>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4 dyp-reveal-stagger">
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card">
            <div class="stat-icon red"><i class="bi bi-chat-dots"></i></div>
            <div class="stat-value">@ViewBag.TotalLogs</div>
            <div class="stat-label">Consultas totales</div>
            <div class="stat-trend"><i class="bi bi-database"></i>Historial completo</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card">
            <div class="stat-icon amber"><i class="bi bi-calendar-day"></i></div>
            <div class="stat-value">@ViewBag.TotalToday</div>
            <div class="stat-label">Consultas hoy</div>
            <div class="stat-trend"><i class="bi bi-clock"></i>UTC de hoy</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card">
            <div class="stat-icon blue"><i class="bi bi-pencil-square"></i></div>
            <div class="stat-value">@ViewBag.TotalWriteActions</div>
            <div class="stat-label">Acciones escritura</div>
            <div class="stat-trend"><i class="bi bi-shield-exclamation"></i>Cambios en BD</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card">
            <div class="stat-icon" style="background:rgba(255,193,7,.12); color:#ffc107;"><i class="bi bi-x-circle"></i></div>
            <div class="stat-value">@ViewBag.TotalErrors</div>
            <div class="stat-label">Errores / denegados</div>
            <div class="stat-trend"><i class="bi bi-slash-circle"></i>Sin permiso o error</div>
        </div>
    </div>
</div>

<!-- Filters -->
<form method="get" class="dyp-summary-box mb-4 d-flex flex-wrap gap-2 align-items-center" style="padding:1rem 1.25rem;">
    <select name="role" class="form-select form-select-sm" style="width:auto; min-width:120px;">
        <option value="">Todos los roles</option>
        <option value="Admin" selected="@(filterRole=="Admin")">Admin</option>
        <option value="User" selected="@(filterRole=="User")">User</option>
        <option value="Anonymous" selected="@(filterRole=="Anonymous")">Anónimo</option>
    </select>

    <select name="intent" class="form-select form-select-sm" style="width:auto; min-width:160px;">
        <option value="">Todas las intenciones</option>
        @foreach (var i in allIntents)
        {
            <option value="@i" selected="@(filterIntent==i)">@i</option>
        }
    </select>

    <div class="form-check mb-0 ms-1">
        <input class="form-check-input" type="checkbox" name="writeOnly" value="true" id="chkWrite"
               @(filterWriteOnly == true ? "checked" : "") />
        <label class="form-check-label small text-secondary" for="chkWrite">Solo escritura</label>
    </div>

    <button type="submit" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-funnel me-1"></i>Filtrar
    </button>
    <a asp-action="ChatLogs" class="btn btn-sm btn-link text-secondary">Limpiar filtros</a>
</form>

<!-- Table desktop -->
<div class="d-none d-lg-block dyp-admin-table">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th style="width:160px;">Fecha / Hora</th>
                    <th style="width:200px;">Usuario</th>
                    <th style="width:80px; text-align:center;">Rol</th>
                    <th>Mensaje</th>
                    <th style="width:160px;">Intención</th>
                    <th style="width:80px; text-align:center;">Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-secondary py-4">No hay registros con los filtros actuales.</td></tr>
                }
                @foreach (var log in Model)
                {
                    <tr class="@(log.IsWriteAction ? "table-warning bg-opacity-10" : "")">
                        <td class="text-secondary small" style="white-space:nowrap;">
                            @log.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm:ss")
                        </td>
                        <td>
                            <div class="fw-semibold small" style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@log.UserEmail">@log.UserEmail</div>
                            @if (log.IpAddress != null)
                            {
                                <div class="text-secondary" style="font-size:.7rem;">@log.IpAddress</div>
                            }
                        </td>
                        <td class="text-center">
                            @if (log.UserRole == "Admin")
                            {
                                <span class="badge" style="background:rgba(255,45,77,.18); color:var(--dyp-red);">Admin</span>
                            }
                            else if (log.UserRole == "User")
                            {
                                <span class="badge bg-primary bg-opacity-25 text-primary">User</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-25 text-secondary">Anón.</span>
                            }
                        </td>
                        <td>
                            <span class="small">@log.Message</span>
                            @if (log.IsWriteAction)
                            {
                                <i class="bi bi-pencil-square text-warning ms-1" title="Acción de escritura"></i>
                            }
                        </td>
                        <td>
                            <code class="small" style="color:var(--dyp-cyan, #7cf);">@log.Intent</code>
                        </td>
                        <td class="text-center">
                            @if (log.IsSuccess)
                            {
                                <i class="bi bi-check-circle-fill text-success" title="Éxito"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle-fill text-danger" title="Error o denegado"></i>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Cards mobile -->
<div class="d-lg-none">
    @if (!Model.Any())
    {
        <p class="text-secondary text-center py-4">No hay registros con los filtros actuales.</p>
    }
    @foreach (var log in Model)
    {
        <div class="dyp-admin-mobile-card mb-2 @(log.IsWriteAction ? "border border-warning border-opacity-25" : "")">
            <div class="d-flex justify-content-between align-items-start mb-1">
                <div>
                    <span class="fw-semibold small">@log.UserEmail</span>
                    @if (log.UserRole == "Admin")
                    {
                        <span class="badge ms-1" style="background:rgba(255,45,77,.18); color:var(--dyp-red); font-size:.65rem;">Admin</span>
                    }
                </div>
                @if (log.IsSuccess)
                {
                    <i class="bi bi-check-circle-fill text-success"></i>
                }
                else
                {
                    <i class="bi bi-x-circle-fill text-danger"></i>
                }
            </div>
            <p class="mb-1 small">"@log.Message"</p>
            <div class="d-flex gap-2 flex-wrap">
                <code style="font-size:.7rem; color:var(--dyp-cyan, #7cf);">@log.Intent</code>
                <span class="text-secondary" style="font-size:.7rem;">@log.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</span>
                @if (log.IsWriteAction)
                {
                    <span class="text-warning" style="font-size:.7rem;"><i class="bi bi-pencil-square"></i> Escritura</span>
                }
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav class="mt-4" aria-label="Paginación auditoría">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link"
                       asp-action="ChatLogs"
                       asp-route-page="@p"
                       asp-route-role="@filterRole"
                       asp-route-intent="@filterIntent"
                       asp-route-writeOnly="@filterWriteOnly">@p</a>
                </li>
            }
        </ul>
    </nav>
}
