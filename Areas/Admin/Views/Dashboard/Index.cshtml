@{ ViewData["Title"] = "Dashboard"; }

<h2 class="fw-bold text-uppercase mb-4">Panel de Administración</h2>

<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card p-4 rounded-3">
            <i class="bi bi-box-seam text-danger fs-1 mb-2"></i>
            <div class="fs-2 fw-bold">@ViewBag.TotalProducts</div>
            <div class="text-secondary small text-uppercase">Productos</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card p-4 rounded-3">
            <i class="bi bi-receipt text-warning fs-1 mb-2"></i>
            <div class="fs-2 fw-bold">@ViewBag.TotalOrders</div>
            <div class="text-secondary small text-uppercase">Pedidos</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card p-4 rounded-3">
            <i class="bi bi-people text-info fs-1 mb-2"></i>
            <div class="fs-2 fw-bold">@ViewBag.TotalUsers</div>
            <div class="text-secondary small text-uppercase">Usuarios</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dyp-stat-card p-4 rounded-3">
            <i class="bi bi-currency-dollar text-success fs-1 mb-2"></i>
            <div class="fs-2 fw-bold">$@((decimal)ViewBag.TotalRevenue).ToString("N0")</div>
            <div class="text-secondary small text-uppercase">Ingresos</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-6">
        <a asp-action="Products" class="text-decoration-none">
            <div class="dyp-admin-card p-4 rounded-3">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-3 p-3" style="background:#dc35451a;"><i class="bi bi-box-seam text-danger fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Gestionar Productos</h5>
                        <small class="text-secondary">Añadir, editar o eliminar inventario.</small>
                    </div>
                </div>
                <span class="btn btn-danger btn-sm">Ir a Productos <i class="bi bi-arrow-right ms-1"></i></span>
            </div>
        </a>
    </div>
    <div class="col-12 col-md-6">
        <a asp-action="Users" class="text-decoration-none">
            <div class="dyp-admin-card p-4 rounded-3">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-3 p-3" style="background:#0d6efd1a;"><i class="bi bi-people text-primary fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Gestionar Usuarios</h5>
                        <small class="text-secondary">Ver usuarios y asignar roles.</small>
                    </div>
                </div>
                <span class="btn btn-primary btn-sm">Ir a Usuarios <i class="bi bi-arrow-right ms-1"></i></span>
            </div>
        </a>
    </div>
    <div class="col-12 col-md-6">
        <a asp-action="Orders" class="text-decoration-none">
            <div class="dyp-admin-card p-4 rounded-3">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-3 p-3" style="background:#ffc1071a;"><i class="bi bi-receipt text-warning fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Gestionar Pedidos</h5>
                        <small class="text-secondary">Ver y actualizar estado de pedidos.</small>
                    </div>
                </div>
                <span class="btn btn-warning btn-sm text-dark">Ir a Pedidos <i class="bi bi-arrow-right ms-1"></i></span>
            </div>
        </a>
    </div>
</div>
