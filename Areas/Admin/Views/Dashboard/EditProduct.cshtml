@model ProductViewModel
@{ ViewData["Title"] = "Editar Producto"; }
<div style="max-width:700px;">
    <h2 class="fw-bold text-uppercase mb-4">Editar Producto</h2>
    <div class="dyp-summary-box rounded-3 p-4">
        <form asp-action="EditProduct" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>
            <div class="row g-3">
                <div class="col-12 col-sm-6">
                    <label asp-for="Name" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Name" class="form-control dyp-input" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12 col-sm-6">
                    <label asp-for="Brand" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Brand" class="form-control dyp-input" />
                    <span asp-validation-for="Brand" class="text-danger small"></span>
                </div>
                <div class="col-12 col-sm-6">
                    <label asp-for="Price" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Price" class="form-control dyp-input" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-12 col-sm-6">
                    <label asp-for="Stock" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="Stock" class="form-control dyp-input" type="number" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Category" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <select asp-for="Category" class="form-select dyp-input">
                        <option value="boxing">Boxeo</option>
                        <option value="shoes">Tenis Deportivos</option>
                        <option value="supplements">Suplementos</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <textarea asp-for="Description" class="form-control dyp-input" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ImageUrl" class="form-label text-secondary small text-uppercase fw-bold"></label>
                    <input asp-for="ImageUrl" class="form-control dyp-input" />
                </div>
            </div>
            <div class="d-flex gap-3 justify-content-end mt-4">
                <a asp-action="Products" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger"><i class="bi bi-check-lg me-1"></i>Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
