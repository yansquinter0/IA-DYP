@model IEnumerable<DYPStore.Models.ApplicationUser>
@{ ViewData["Title"] = "Usuarios"; var roles = ViewBag.UserRoles as Dictionary<string, IList<string>>; }

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <div class="dyp-section-eyebrow">Comunidad</div>
        <h2 class="dyp-section-title mb-0">Gestión de Usuarios</h2>
    </div>
    <span class="badge bg-secondary px-3 py-2"><i class="bi bi-people me-1"></i>@Model.Count() usuarios</span>
</div>

<div class="dyp-summary-box mb-4" style="padding: 1.25rem 1.5rem;">
    <div class="dyp-search-pill" style="max-width:420px;">
        <i class="bi bi-search text-secondary me-2"></i>
        <input type="search" placeholder="Buscar por nombre o correo..." data-table-search=".dyp-user-row, .dyp-user-mobile" />
    </div>
</div>

<div class="d-none d-md-block dyp-admin-table">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var userRoles = roles?[u.Id] ?? new List<string>();
                    var isAdmin = userRoles.Contains("Admin");
                    var initials = string.Join("", (u.FullName ?? u.Email ?? "?").Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString() : ""));
                    <tr class="dyp-user-row">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="dyp-avatar">@initials</div>
                                <div class="text-white fw-semibold">@u.FullName</div>
                            </div>
                        </td>
                        <td class="text-secondary">@u.Email</td>
                        <td>
                            @if (isAdmin)
                            {
                                <span class="badge bg-danger px-3 py-2"><i class="bi bi-shield-lock-fill me-1"></i>Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-3 py-2"><i class="bi bi-person me-1"></i>Usuario</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="ToggleAdmin" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-sm @(isAdmin?"btn-outline-secondary":"btn-outline-success") me-1">
                                    <i class="bi bi-@(isAdmin?"shield-x":"shield-check") me-1"></i>@(isAdmin?"Quitar Admin":"Hacer Admin")
                                </button>
                            </form>
                            <form asp-action="DeleteUser" method="post" class="d-inline" data-confirm="¿Eliminar a @u.FullName? Esta acción no se puede deshacer.">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-md-none">
    @foreach (var u in Model)
    {
        var userRoles = roles?[u.Id] ?? new List<string>();
        var isAdmin = userRoles.Contains("Admin");
        var initials = string.Join("", (u.FullName ?? u.Email ?? "?").Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString() : ""));
        <div class="dyp-summary-box mb-3 dyp-user-mobile" style="padding:1rem;">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div class="dyp-avatar">@initials</div>
                <div class="flex-grow-1 min-w-0">
                    <div class="fw-semibold text-white text-truncate">@u.FullName</div>
                    <div class="text-secondary small text-truncate">@u.Email</div>
                </div>
                <span class="badge @(isAdmin?"bg-danger":"bg-secondary")">@(isAdmin?"Admin":"Usuario")</span>
            </div>
            <div class="d-flex gap-2">
                <form asp-action="ToggleAdmin" method="post" class="flex-grow-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@u.Id" />
                    <button type="submit" class="btn btn-sm @(isAdmin?"btn-outline-secondary":"btn-outline-success") w-100">
                        <i class="bi bi-@(isAdmin?"shield-x":"shield-check") me-1"></i>@(isAdmin?"Quitar Admin":"Hacer Admin")
                    </button>
                </form>
                <form asp-action="DeleteUser" method="post" data-confirm="¿Eliminar?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@u.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                </form>
            </div>
        </div>
    }
</div>
