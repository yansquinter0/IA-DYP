@model IEnumerable<DYPStore.Models.ApplicationUser>
@{ ViewData["Title"] = "Usuarios"; var roles = ViewBag.UserRoles as Dictionary<string, IList<string>>; }

<h2 class="fw-medium text-uppercase mb-4">Gestión de Usuarios</h2>

<!-- Desktop table -->
<div class="d-none d-md-block dyp-summary-box rounded-3 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead style="background:#111;border-bottom:1px solid #333;">
                <tr class="text-secondary text-uppercase small">
                    <th class="p-3">Nombre</th><th class="p-3">Email</th>
                    <th class="p-3">Rol</th><th class="p-3 text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var userRoles = roles?[u.Id] ?? new List<string>();
                    var isAdmin = userRoles.Contains("Admin");
                    <tr style="border-bottom:1px solid #1f1f1f;">
                        <td class="p-3 fw-normal text-light align-middle">@u.FullName</td>
                        <td class="p-3 text-secondary align-middle">@u.Email</td>
                        <td class="p-3 align-middle">
                            <span class="badge @(isAdmin?"bg-danger":"bg-secondary") fw-normal">@(isAdmin?"Admin":"Usuario")</span>
                        </td>
                        <td class="p-3 text-end align-middle">
                            <form asp-action="ToggleAdmin" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-sm @(isAdmin?"btn-outline-secondary":"btn-outline-success") me-1 fw-normal">
                                    <i class="bi bi-@(isAdmin?"shield-x":"shield-check") me-1"></i>
                                    @(isAdmin?"Quitar Admin":"Hacer Admin")
                                </button>
                            </form>
                            <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar a @u.FullName?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Mobile cards -->
<div class="d-md-none">
    @foreach (var u in Model)
    {
        var userRoles = roles?[u.Id] ?? new List<string>();
        var isAdmin = userRoles.Contains("Admin");
        <div class="dyp-summary-box rounded-3 p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <div class="flex-grow-1 min-w-0">
                    <div class="fw-bold small">@u.FullName</div>
                    <div class="text-secondary small text-truncate">@u.Email</div>
                    <span class="badge @(isAdmin?"bg-danger":"bg-secondary") mt-1">@(isAdmin?"Admin":"Usuario")</span>
                </div>
                <div class="d-flex gap-1 flex-shrink-0">
                    <form asp-action="ToggleAdmin" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <button type="submit" class="btn btn-sm @(isAdmin?"btn-outline-secondary":"btn-outline-success")" title="@(isAdmin?"Quitar Admin":"Hacer Admin")">
                            <i class="bi bi-@(isAdmin?"shield-x":"shield-check")"></i>
                        </button>
                    </form>
                    <form asp-action="DeleteUser" method="post" onsubmit="return confirm('¿Eliminar?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@u.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
