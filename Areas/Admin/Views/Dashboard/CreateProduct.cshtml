@model ProductViewModel
@{ ViewData["Title"] = "Nuevo Producto"; }

<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-2">
    <div>
        <nav class="text-secondary small mb-1">
            <a asp-action="Products" class="text-secondary text-decoration-none">Productos</a>
            <i class="bi bi-chevron-right mx-1" style="font-size:.7em;"></i>
            <span class="text-white">Nuevo</span>
        </nav>
        <h2 class="dyp-section-title mb-0">Nuevo Producto</h2>
    </div>
    <a asp-action="Products" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<form asp-action="CreateProduct" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <div class="dyp-summary-box">
                <h5 class="fw-bold text-uppercase mb-3" style="font-family:'Barlow Condensed',sans-serif; letter-spacing:.05em;"><i class="bi bi-info-circle me-2 text-danger"></i>Información del producto</h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label">Nombre del producto</label>
                        <input asp-for="Name" class="form-control dyp-input" placeholder="Ej: Guantes Pro Boxing 12oz" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="Brand" class="form-label">Marca</label>
                        <input asp-for="Brand" class="form-control dyp-input" placeholder="Ej: Everlast" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="Category" class="form-label">Categoría</label>
                        <select asp-for="Category" class="form-select dyp-input">
                            <option value="boxing">Boxeo</option>
                            <option value="shoes">Tenis Deportivos</option>
                            <option value="supplements">Suplementos</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label d-flex justify-content-between"><span>Descripción</span><small class="text-secondary fw-normal text-lowercase" style="letter-spacing:0;" id="descCounter"></small></label>
                        <textarea asp-for="Description" class="form-control dyp-input" rows="4" maxlength="500" placeholder="Cuéntanos qué hace especial este producto..." data-char-counter="#descCounter"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="dyp-summary-box mt-4">
                <h5 class="fw-bold text-uppercase mb-3" style="font-family:'Barlow Condensed',sans-serif; letter-spacing:.05em;"><i class="bi bi-cash-stack me-2 text-danger"></i>Precio e Inventario</h5>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label asp-for="Price" class="form-label">Precio (COP)</label>
                        <input asp-for="Price" class="form-control dyp-input" type="number" step="0.01" placeholder="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="Stock" class="form-label">Stock disponible</label>
                        <input asp-for="Stock" class="form-control dyp-input" type="number" placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="dyp-summary-box" style="position:sticky; top:90px;">
                <h5 class="fw-bold text-uppercase mb-3" style="font-family:'Barlow Condensed',sans-serif; letter-spacing:.05em;"><i class="bi bi-image me-2 text-danger"></i>Imagen</h5>
                <label asp-for="ImageUrl" class="form-label">URL de la imagen</label>
                <input asp-for="ImageUrl" class="form-control dyp-input" placeholder="https://..." data-image-preview-source="#imgPreview" />
                <div id="imgPreview" class="dyp-image-preview">La vista previa de la imagen aparecerá aquí</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-end mt-4 sticky-bottom py-3" style="background: linear-gradient(180deg, transparent, var(--dyp-bg) 30%);">
        <a asp-action="Products" class="btn btn-outline-light">Cancelar</a>
        <button type="submit" class="btn btn-danger px-4"><i class="bi bi-check-lg me-1"></i>Crear Producto</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
