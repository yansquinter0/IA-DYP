@model IEnumerable<Product>
@{ ViewData["Title"] = "Productos"; }

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <h2 class="fw-bold text-uppercase mb-0">Gestión de Productos</h2>
    <a asp-action="CreateProduct" class="btn btn-danger"><i class="bi bi-plus-lg me-1"></i>Nuevo Producto</a>
</div>

<!-- Desktop table -->
<div class="d-none d-md-block dyp-summary-box rounded-3 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead style="background:#111;border-bottom:1px solid #333;">
                <tr class="text-secondary text-uppercase small">
                    <th class="p-3">Producto</th><th class="p-3">Marca</th><th class="p-3">Categoría</th>
                    <th class="p-3">Precio</th><th class="p-3">Stock</th><th class="p-3 text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr style="border-bottom:1px solid #1f1f1f;">
                        <td class="p-3 fw-bold">@p.Name</td>
                        <td class="p-3 text-secondary">@p.Brand</td>
                        <td class="p-3"><span class="dyp-badge-cat dyp-cat-@p.Category.ToString().ToLower()">@p.Category.ToString().ToUpper()</span></td>
                        <td class="p-3 text-danger fw-bold">$@p.Price.ToString("N2")</td>
                        <td class="p-3">@p.Stock</td>
                        <td class="p-3 text-end">
                            <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar @p.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Mobile cards -->
<div class="d-md-none">
    @foreach (var p in Model)
    {
        <div class="dyp-summary-box rounded-3 p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                        <span class="dyp-badge-cat dyp-cat-@p.Category.ToString().ToLower()" style="font-size:.65rem">@p.Category.ToString().ToUpper()</span>
                        <small class="text-secondary">@p.Brand</small>
                    </div>
                    <div class="fw-bold small mb-1">@p.Name</div>
                    <div class="d-flex gap-3">
                        <span class="text-danger fw-bold small">$@p.Price.ToString("N2")</span>
                        <small class="text-secondary">Stock: @p.Stock</small>
                    </div>
                </div>
                <div class="d-flex gap-1 flex-shrink-0">
                    <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                    <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
