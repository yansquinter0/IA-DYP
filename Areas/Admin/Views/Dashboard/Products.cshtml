@model IEnumerable<Product>
@{ ViewData["Title"] = "Productos"; }

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <div>
        <div class="dyp-section-eyebrow">Catálogo</div>
        <h2 class="dyp-section-title mb-0">Gestión de Productos</h2>
    </div>
    <a asp-action="CreateProduct" class="btn btn-danger"><i class="bi bi-plus-lg me-1"></i>Nuevo Producto</a>
</div>

<div class="dyp-summary-box mb-4 d-flex flex-wrap gap-3 align-items-center justify-content-between" style="padding: 1.25rem 1.5rem;">
    <div class="dyp-search-pill" style="flex:1; min-width:260px; max-width:420px;">
        <i class="bi bi-search text-secondary me-2"></i>
        <input type="search" placeholder="Buscar por nombre, marca o categoría..." data-table-search=".dyp-prod-row, .dyp-prod-mobile" />
    </div>
    <div class="text-secondary small"><i class="bi bi-collection me-1"></i><strong class="text-white">@Model.Count()</strong> productos en total</div>
</div>

<div class="d-none d-md-block dyp-admin-table">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="dyp-prod-row">
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(p.ImageUrl ?? "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=120&q=80")" alt="@p.Name" class="dyp-thumb-sm" />
                                <div class="min-w-0">
                                    <div class="fw-semibold text-white text-truncate" style="max-width:280px;">@p.Name</div>
                                    <div class="dyp-brand">@p.Brand</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="dyp-badge-cat dyp-cat-@p.Category.ToString().ToLower()" style="position:static;">@p.Category.ToString()</span></td>
                        <td class="text-danger fw-bold">$@p.Price.ToString("N0")</td>
                        <td>
                            @if (p.Stock > 5) { <span class="dyp-stock-pill">@p.Stock</span> }
                            else if (p.Stock > 0) { <span class="dyp-stock-pill low">@p.Stock</span> }
                            else { <span class="dyp-stock-pill out">0</span> }
                        </td>
                        <td class="text-end">
                            <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-light me-1" title="Editar"><i class="bi bi-pencil"></i></a>
                            <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" class="d-inline" data-confirm="¿Eliminar @p.Name? Esta acción no se puede deshacer.">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"><i class="bi bi-trash3"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-md-none">
    @foreach (var p in Model)
    {
        <div class="dyp-summary-box mb-3 dyp-prod-mobile" style="padding:1rem;">
            <div class="d-flex gap-3">
                <img src="@(p.ImageUrl ?? "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=120&q=80")" alt="@p.Name" style="width:64px; height:64px; border-radius:10px; object-fit:cover;" />
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                        <span class="dyp-badge-cat dyp-cat-@p.Category.ToString().ToLower()" style="position:static; font-size:.6rem;">@p.Category.ToString()</span>
                        <small class="dyp-brand">@p.Brand</small>
                    </div>
                    <div class="fw-semibold small text-white text-truncate">@p.Name</div>
                    <div class="d-flex gap-3 mt-1">
                        <span class="text-danger fw-bold small">$@p.Price.ToString("N0")</span>
                        <small class="text-secondary">Stock: @p.Stock</small>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-light flex-grow-1"><i class="bi bi-pencil me-1"></i>Editar</a>
                <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" data-confirm="¿Eliminar?">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></button>
                </form>
            </div>
        </div>
    }
</div>
