@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07070a" />
    <title>Admin · @ViewData["Title"] · DYPStore</title>
    <script>
        (function(){
            try {
                var t = JSON.parse(localStorage.getItem('dypx_theme')) || 'dark';
                document.documentElement.setAttribute('data-theme', t);
            } catch(e){}
        })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<nav class="navbar dyp-navbar px-3 px-md-4 sticky-top">
    <div class="d-flex w-100 align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <a class="navbar-brand dyp-logo m-0" asp-controller="Home" asp-action="Index" asp-area="">
                <span class="dyp-logo-mark"><i class="bi bi-lightning-charge-fill"></i></span>
                DYP<span class="text-danger">Store</span>
            </a>
            <span class="badge" style="background:rgba(255,45,77,.14); color:var(--dyp-red); padding:6px 10px; border-radius:999px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; font-size:.7rem;">
                <i class="bi bi-shield-lock-fill me-1"></i>Panel Admin
            </span>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <button type="button" class="dyp-theme-toggle" title="Cambiar tema" aria-label="Cambiar tema"><i class="bi bi-sun-fill"></i></button>
            <a class="dyp-icon-btn" asp-controller="Home" asp-action="Index" asp-area="" title="Ver tienda" aria-label="Ver tienda"><i class="bi bi-house"></i></a>
            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="dyp-icon-btn" title="Cerrar sesión" aria-label="Cerrar sesión"><i class="bi bi-box-arrow-right"></i></button>
            </form>
        </div>
    </div>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="display:none;">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger" style="display:none;">@TempData["Error"]</div>
}

<div class="d-flex flex-column flex-md-row" style="min-height: calc(100vh - 65px);">
    <aside class="admin-sidebar">
        <ul class="nav flex-column">
            <li class="sidebar-section">Vista general</li>
            <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @(action=="Index"?"active":"")"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
            <li class="sidebar-section">Catálogo</li>
            <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Products" class="nav-link @(action=="Products"||action=="CreateProduct"||action=="EditProduct"?"active":"")"><i class="bi bi-box-seam"></i>Productos</a></li>
            <li class="sidebar-section">Operaciones</li>
            <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Orders" class="nav-link @(action=="Orders"?"active":"")"><i class="bi bi-receipt"></i>Pedidos</a></li>
            <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Users" class="nav-link @(action=="Users"?"active":"")"><i class="bi bi-people"></i>Usuarios</a></li>
            <li class="sidebar-section">Inteligencia Artificial</li>
            <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="ChatLogs" class="nav-link @(action=="ChatLogs"?"active":"")"><i class="bi bi-chat-dots"></i>Auditoría IA</a></li>
            <li class="sidebar-section">Tienda</li>
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" asp-area="" class="nav-link"><i class="bi bi-arrow-left-circle"></i>Volver a la tienda</a></li>
        </ul>
    </aside>
    <main class="flex-grow-1 p-3 p-md-4 p-lg-5">@RenderBody()</main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
